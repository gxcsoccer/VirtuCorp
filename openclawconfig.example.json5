// VirtuCorp — Example OpenClaw Configuration
//
// Copy relevant sections into your ~/.openclaw/openclaw.json and fill in your values.
// Then start openclaw and run /vc-init to set up the target repo.

{
  // ── Model Providers ────────────────────────────────────
  // Configure the LLM providers your agents will use.
  // VirtuCorp supports any OpenAI-compatible API.
  models: {
    mode: "merge",
    providers: {
      // Example: Alibaba Cloud Bailian (recommended for Chinese users)
      "bailian": {
        baseUrl: "https://coding.dashscope.aliyuncs.com/v1",
        apiKey: "${BAILIAN_API_KEY}",          // ← CHANGE THIS
        api: "openai-completions",
        models: [
          {
            id: "qwen3.5-plus",
            name: "Qwen 3.5 Plus",
            reasoning: true,
            input: ["text", "image"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 1000000,
            maxTokens: 65536,
          },
          {
            id: "qwen3-coder-plus",
            name: "Qwen 3 Coder Plus",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 1000000,
            maxTokens: 65536,
          },
          {
            id: "kimi-k2.5",
            name: "Kimi K2.5",
            reasoning: true,
            input: ["text", "image"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 262144,
            maxTokens: 32768,
          },
        ],
      },
      // Example: Local MLX model (optional, for offline use)
      // "custom-127-0-0-1-8000": {
      //   baseUrl: "http://127.0.0.1:8000/v1",
      //   apiKey: "mlx",
      //   api: "openai-completions",
      //   models: [{ id: "qwen3.5-35b-4bit", name: "qwen3.5-35b-4bit (MLX)", ... }],
      // },
    },
  },

  // ── CEO Agent ──────────────────────────────────────────
  // The CEO is a top-level agent that dispatches work to sub-agents.
  agents: {
    defaults: {
      model: { primary: "bailian/qwen3.5-plus" },
      compaction: { mode: "safeguard" },
      timeoutSeconds: 600,
      maxConcurrent: 5,
      subagents: { maxConcurrent: 8 },

      // Heartbeat: CEO's autonomous pulse.
      // Checks GitHub state and dispatches work on each tick.
      heartbeat: {
        every: "30m",
        model: "bailian/kimi-k2.5",       // Use cheaper model for heartbeat checks
        target: "last",                    // Default: continue last conversation
      },
    },

    list: [
      {
        id: "virtucorp-ceo",
        name: "VirtuCorp CEO",
        workspace: "/path/to/AlphaArena",  // ← CHANGE THIS: local project clone
        model: "bailian/qwen3.5-plus",
        heartbeat: {
          every: "10m",                    // CEO checks more frequently
          model: "bailian/kimi-k2.5",
          target: "feishu",                // Announce to Feishu group
          to: "chat:${FEISHU_GROUP_ID}",   // ← CHANGE THIS: your Feishu group chat ID
          activeHours: { start: "08:00", end: "23:00" },  // Respect quiet hours
        },
        skills: ["exa-web-search", "jina-reader", "github"],
        tools: {
          allow: [
            "read", "write", "edit", "exec", "process",
            "web_search", "web_fetch",
            "sessions_spawn", "sessions_list", "sessions_history",
            "session_status", "sessions_send",
            "memory_search", "memory_get",
            // VirtuCorp-specific tools (registered by plugin)
            "vc_review_pr", "vc_merge_pr",
            "vc_save_knowledge", "vc_search_knowledge", "vc_list_knowledge",
          ],
        },
      },
    ],
  },

  // ── Feishu Channel Binding ─────────────────────────────
  // Route messages from a specific Feishu group to the CEO agent.
  bindings: [
    {
      type: "route",
      agentId: "virtucorp-ceo",
      match: {
        channel: "feishu",
        peer: {
          kind: "group",
          id: "${FEISHU_GROUP_ID}",        // ← CHANGE THIS: e.g. "oc_xxxxx"
        },
      },
    },
  ],

  // ── VirtuCorp Plugin ────────────────────────────────────
  plugins: {
    allow: ["virtucorp", "feishu"],
    load: {
      // Point to where you cloned VirtuCorp
      paths: ["/path/to/VirtuCorp/extensions/virtucorp"],  // ← CHANGE THIS
    },
    entries: {
      virtucorp: {
        enabled: true,
        config: {
          github: {
            owner: "your-github-user",     // ← CHANGE THIS
            repo: "your-repo",             // ← CHANGE THIS
          },

          // Absolute path to your local clone of the target project
          projectDir: "/path/to/your/project",  // ← CHANGE THIS

          sprint: {
            durationDays: 1,               // 1 = daily sprints
            autoRetro: true,
          },

          budget: {
            dailyLimitUsd: 10,             // Daily token spend limit
            circuitBreakerRetries: 3,      // Max retries per issue before escalating
          },

          // Model assignment per role
          // CEO delegates to these specialized models
          roles: {
            pm:  { model: "bailian/qwen3.5-plus" },       // Strategic thinking
            dev: { model: "bailian/glm-5" },                // Coding ability
            qa:  { model: "bailian/qwen3.5-plus" },        // Review reasoning
            ops: { model: "bailian/kimi-k2.5" },           // Ops tasks
          },
        },
      },
      feishu: { enabled: true },
    },
  },

  // ── Feishu Channel ────────────────────────────────────
  channels: {
    feishu: {
      enabled: true,
      appId: "${FEISHU_APP_ID}",           // ← CHANGE THIS
      appSecret: "${FEISHU_APP_SECRET}",   // ← CHANGE THIS
      connectionMode: "websocket",
      domain: "feishu",                    // "feishu" for feishu.cn, "lark" for lark.suite
      dmPolicy: "open",
      groupPolicy: "open",
      requireMention: true,                // Bot must be @mentioned in groups
      allowFrom: ["*"],
    },
  },

  // ── Messages ──────────────────────────────────────────
  messages: {
    ackReactionScope: "group-mentions",    // Only ack messages that @mention the bot
  },

  // ── Cron Jobs ──────────────────────────────────────────
  // Set up after deployment via CLI:
  //
  // Daily structured report (8 PM Beijing time):
  //   openclaw cron add \
  //     --name "VirtuCorp 每日报告" \
  //     --agent virtucorp-ceo \
  //     --cron "0 20 * * *" \
  //     --tz "Asia/Shanghai" \
  //     --channel feishu \
  //     --to "chat:${FEISHU_GROUP_ID}" \
  //     --message "请生成今日 Sprint 进度报告，包括：1) 今日完成的工作 2) 进行中的工作 3) 阻塞项和风险 4) 明日计划" \
  //     --announce

  // ── Gateway ────────────────────────────────────────────
  gateway: {
    port: 18789,
    mode: "local",
    bind: "lan",
    auth: {
      mode: "token",
      token: "${GATEWAY_TOKEN}",           // ← CHANGE THIS: generate with `openssl rand -hex 24`
    },
  },
}
